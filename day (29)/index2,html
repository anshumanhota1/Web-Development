<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Card Design</title>
  <style>
    body {
      background-color: #e6f0f3;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .card {
      background-color: #fff;
      border-radius: 15px;
      box-shadow: 0 4px 8px rgba(0,0,0,0.1);
      overflow: hidden;
      width: 320px;
      text-align: left;
      padding-bottom: 20px;
    }

    .card img {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }

    .card-content {
      padding: 20px;
    }

    .tags {
      display: flex;
      gap: 10px;
      margin-bottom: 10px;
    }

    .tag {
      background-color: #f1f5f9;
      color: #4b5563;
      padding: 4px 12px;
      border-radius: 9999px;
      font-size: 12px;
      font-weight: 500;
    }

    .title {
      font-size: 22px;
      font-weight: 600;
      color: #111827;
      margin: 10px 0;
    }

    .description {
      color: #6b7280;
      font-size: 14px;
      line-height: 1.5;
    }

    .read-more {
      display: inline-block;
      margin-top: 15px;
      padding: 10px 20px;
      background-color: #dbeafe;
      color: #2563eb;
      border: none;
      border-radius: 9999px;
      text-decoration: none;
      font-weight: 500;
      font-size: 14px;
      transition: background-color 0.3s ease;
    }

    .read-more:hover {
      background-color: #bfdbfe;
    }
  </style>
</head>
<body>

  <div class="card">
    <img src="https://images.unsplash.com/photo-1511512578047-dfb367046420?auto=format&fit=crop&w=800&q=80" alt="Lago di Braies" />
    <div class="card-content">
      <div class="tags">
        <span class="tag">Nature</span>
        <span class="tag">Lake</span>
      </div>
      <div class="title">Lago di Braies</div>
      <div class="description">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Consectetur sodales morbi dignissim sed diam pharetra vitae ipsum odio.
      </div>
      <a href="#" class="read-more">Read More</a>
    </div>
  </div>

</body>
</html>
